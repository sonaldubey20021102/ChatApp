@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}
<style>
    .show{
        display:block !important;
    }
    .hide{
        display:none;
    }


</style>

<div wrap-content style="display:none;">
    <input type="hidden" id="userId"/>
    <h5>Welcome <b user></b></h5>

    <input placeholder="type your message" id="msg_content" />
    <button onclick="sendMessage()"> send message </button>
</div>

<script>

    CreateUser()

    async function CreateUser()
    {
        var username = prompt("Enter Your name ..")
        if(username) {
            const formdata = new FormData();
            formdata.append("UserName", username);
           const response= await fetch('/User/CreateUser',{
               method:'post',
               body:formdata
           });
           const result = await response.json();

           if(result>0){
                document.querySelector('[user]').innerHTML=username
                document.querySelector('[wrap-content]').className="show";
           } else document.querySelector('[wrap-content]').className="hide";


           console.log(result)
           document.querySelector('#userId').value = result;

        }
    }


    connectToChatHub();

    function sendMessage() {
        const formdata = new FormData();
        formdata.append("message", document.querySelector('#msg_content').value);
        formdata.append("UserId", document.querySelector('#userId').value);

        const response = fetch('/chathub/sendMsg', {method: 'post', body: formdata});
        console.log('MessageChannel sent')
    }

    async function  connectToChatHub() {
        const response = await fetch('/chathub/ListenMessages')
        const reader = response.body.getReader();
        const decoder = new TextDecoder()

        while(true) {
            const stream = await reader.read();
            if(stream.done) break;
            
            var text = decoder.decode(stream.value)

            console.log(text);
        }
    }

</script>